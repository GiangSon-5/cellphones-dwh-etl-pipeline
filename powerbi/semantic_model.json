{
  "name": "CellphoneS_Retail_Semantic_Model",
  "version": "1.0",
  "tables": [
    {
      "name": "dim_store",
      "columns": ["store_id", "store_name", "region", "regional_sales_manager", "area_manager", "store_type", "store_tier"]
    },
    {
      "name": "dim_product",
      "columns": ["product_sk", "product_id", "product_name", "brand", "category", "base_price", "is_current"]
    },
    {
      "name": "fact_sales",
      "columns": ["transaction_id", "transaction_date", "store_id", "product_id", "product_sk", "quantity", "unit_price", "total_amount"]
    },
    {
      "name": "fact_inventory_daily",
      "columns": ["log_date", "store_id", "product_id", "beginning_inventory", "received_quantity", "sold_quantity", "ending_inventory", "daily_run_rate", "inventory_to_sales_ratio", "inventory_health_status"]
    }
  ],
  "relationships": [
    {
      "name": "rel_store_sales",
      "fromTable": "fact_sales",
      "fromColumn": "store_id",
      "toTable": "dim_store",
      "toColumn": "store_id",
      "cardinality": "manyToOne"
    },
    {
      "name": "rel_product_sales",
      "fromTable": "fact_sales",
      "fromColumn": "product_sk",
      "toTable": "dim_product",
      "toColumn": "product_sk",
      "cardinality": "manyToOne"
    },
    {
      "name": "rel_store_inventory",
      "fromTable": "fact_inventory_daily",
      "fromColumn": "store_id",
      "toTable": "dim_store",
      "toColumn": "store_id",
      "cardinality": "manyToOne"
    }
  ]
}
